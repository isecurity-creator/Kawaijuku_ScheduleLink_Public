{
    "manifest_version": 3,
    "name": "Kawaijuku_roomID_get",
    "description": "河合塾の塾生マイページを開いたときに、この先の授業がある教室の番号を取得し、Google Calenderに自動登録します。",
    "version": "1.0",
    "icons": {
        "16": "images/icon-16.png",
        "32": "images/icon-32.png",
        "48": "images/icon-48.png"
    },
    "permissions": [
        "scripting",
        "activeTab"
    ],
    "host_permissions": [
        "https://script.google.com/*"
    ],
    "content_scripts": [
        {
            "js": [
                "data_get_autoyear.js"
            ],
            "matches": [
                "https://j-mypage.kawai-juku.ac.jp/jmenu/*"
            ]
        }
    ]
}